# The .env file should have your own personal API Keys
# Your local .env file should be preserved through .gitignore
# Here is an example structure for your local .env file
#--- AI
OPENROUTER_API_KEY="<YOUR_API_KEY>"

#--- Skills
# VirusTotal (free tier): https://www.virustotal.com/gui/sign-in → API key
VIRUSTOTAL_API_KEY="<YOUR_VT_API_KEY>"

#--- Database
# SQLite is used by default — no DATABASE_URL needed.
# The DB file is created automatically at ~/.charles/charles.db
# Override the data directory:
# CHARLES_DATA_DIR="/path/to/custom/data"
# Or override the full URL (e.g., for testing):
# DATABASE_URL="sqlite+aiosqlite:///./local.db"