{
  "name": "charles",
  "version": "1.1.2",
  "description": "Charles AI assistant desktop app",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "predist": "pwsh -ExecutionPolicy Bypass -File ../scripts/setup-embedded-python.ps1",
    "dist": "electron-builder"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.charles.assistant",
    "productName": "Charles",
    "win": {
      "target": "nsis",
      "artifactName": "Charles.Setup.${version}.exe"
    },
    "extraResources": [
      {
        "from": "../api",
        "to": "api"
      },
      {
        "from": "../voice",
        "to": "voice"
      },
      {
        "from": "../resources/python",
        "to": "python"
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "JustinSu11",
      "repo": "charles"
    }
  }
}
